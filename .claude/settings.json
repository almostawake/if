{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -d \"$HOME/Applications/Chrome with Claude Code.app\" ] && open -ga \"Chrome with Claude Code\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hook-block-direct-auth.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hook-block-chrome-direct.mjs"
          }
        ]
      }
    ]
  }
}
