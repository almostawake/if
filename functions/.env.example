# Shared secret that external callers must present in `Authorization: Bearer <value>`
# to reach the `api` function. Any inbound HTTP endpoint in this project is gated by
# this. Set to a long random string. Auto-loaded by Firebase Functions Gen 2 from
# functions/.env at runtime; gitignored at the repo root.
CODE_THAT_OTHER_SERVICES_NEED_TO_GET_PAST_OUR_BOUNCER=
