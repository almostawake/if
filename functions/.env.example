# Shared secret that external callers must present in `Authorization: Bearer <value>`
# to reach the `api` function. Any inbound HTTP endpoint in this project is gated by
# this. Set to a long random string. Auto-loaded by Firebase Functions Gen 2 from
# functions/.env at runtime; gitignored at the repo root.
CODE_THAT_OTHER_SERVICES_NEED_TO_GET_PAST_OUR_BOUNCER=

# OAuth 2.0 Web Client (Cloud Console → Google Auth Platform → Clients).
# Same client serves prod + emulator (both redirect URIs registered on it).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Scopes the permission-grant flow asks consenting users for. Space-separated, in
# OAuth wire format. Must also be registered on the consent screen in Cloud Console
# (Google Auth Platform → Data access) — keep this list and that screen in sync.
# `openid email` are added by the code separately to identify the consenter.
ADMIN_CONSENTS=https://www.googleapis.com/auth/gmail.modify https://www.googleapis.com/auth/calendar.events
