node_modules/
client/node_modules/
client/build/
client/.svelte-kit/
client/static/*.json
functions/node_modules/
functions/lib/
# Generated per-build from .env by cmd-region.mjs — bakes the deploy region
# into source for functions discovery. Regenerated every build, never committed.
functions/src/region.ts

# Firebase
firebase-debug.log
firestore-debug.log
ui-debug.log
.firebase/

# Env
.env
.env.local
.env.*.local
# Google OAuth creds now live at ~/.if/creds/.env.auth.<email>.json
# (out-of-tree). These patterns stay here defensively — if an old
# checkout or a stray script ever writes one into the project, we still
# refuse to commit it.
.env.auth.json
.env.auth.*.json
# Synthesized ADC creds for firebase-tools, written/cleaned by
# cmd-deploy.mjs on each deploy. Same refresh token as the cred file.
.adc.json
# Per-project Firebase Web config (VITE_FIREBASE_*). Public-bundled
# config, but project-specific so not template-generic.
client/.env
# Per-project functions env (e.g. INCOMING_API_KEY equivalents).
functions/.env

# Firebase emulator persistence (--export-on-exit / --import target).
emulator-data/
# Stranded export dirs left behind when emulators are killed mid-export.
firebase-export-*/

# Scratch dir for screenshots, transient notes, anything we don't want
# committed but might want to keep around between runs.
.tmp/

# OS
.DS_Store
