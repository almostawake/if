# Root .env — n copies this to .env at provisioning and fills the values
# below (same copy-then-fill pattern as functions/.env.example). .env is
# gitignored; local to each checkout.

# The GCP/Firebase project id.
THIS_PROJECT_ID_ON_GOOGLE_HOSTING=

# The project's immutable Firestore region. The functions build bakes this
# into functions/src/region.ts so Cloud Functions deploy alongside their data.
THIS_PROJECT_REGION_ON_GOOGLE_HOSTING=

# The Google account this checkout deploys as. Required — used by
# cmd-deploy.mjs to locate the OAuth cred at
# ~/.if/creds/google.<email>.json, and by cmd-auth.mjs as the default
# account when no positional arg is given.
EMAIL_OF_GOOGLE_HOSTING_ACCOUNT=
