#!/bin/bash
#
# b — refresh ~/.if/staging from origin, then run n (new-project).
#
# Designed to be bound to a shell alias for fast invocation:
#   alias if-new='bash ~/.if/staging/scripts/b'
#
# `git pull --ff-only` keeps the staging clone honest: refuses to merge
# if local edits have diverged from origin. If that happens you'll see
# the git error; cd in and reconcile manually.
#
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR/.."
git pull --ff-only --quiet
exec bash "$SCRIPT_DIR/n" "$@"
