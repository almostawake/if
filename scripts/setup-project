_prov_firestore()               { create_firestore "$PID"; }
_prov_storage()                 { create_storage_bucket "$PID"; }
_prov_auth()                    { configure_auth "$PID"; }

# draw_prov_row "$i" "$state"  — state: done | running | pending | failed
draw_prov_row() {
  local i="$1" state="$2"
  local icon color label
  case "$state" in
    done)    icon="${C_GRN}✓${C_RST}";  color="$C_GRN";  label="${PROV_DONE[$i]}"    ;;
    running) icon="${C_GRAY}⋯${C_RST}"; color="$C_GRAY"; label="${PROV_RUNNING[$i]}" ;;
    pending) icon="${C_GRAY}○${C_RST}"; color="$C_GRAY"; label="${PROV_PENDING[$i]}" ;;
    failed)  icon="${C_RED}✗${C_RST}";  color="$C_RED";  label="${PROV_RUNNING[$i]}" ;;
  esac
  printf '%b  %b%s%b\n' "$icon" "$color" "$label" "$C_RST"
}

# update_prov_row — move cursor up to row i, redraw, return cursor.
# Assumes cursor is on the line just below the last row.
update_prov_row() {
  local i="$1" state="$2"
  local up=$((PROV_N - i))
  printf '\033[%dA\r\033[K' "$up"
  draw_prov_row "$i" "$state"
  local down=$((PROV_N - i - 1))
  if [ "$down" -gt 0 ]; then
    printf '\033[%dB\r' "$down"
  fi
}

# Provisioning orchestrator. Renders all rows pending, runs each step
# in order, animating the row in place. On failure, marks the row red,
# prints a hint if it's a known cause, and returns 1.
provision_all() {
  local i fn rc

  for i in $(seq 0 $((PROV_N - 1))); do
    draw_prov_row "$i" "pending"
  done

  for i in "${!PROV_FNS[@]}"; do
    fn="${PROV_FNS[$i]}"
    update_prov_row "$i" "running"
    rc=0
    "$fn" || rc=$?
    if [ "$rc" -eq 0 ]; then
      update_prov_row "$i" "done"
    else
      update_prov_row "$i" "failed"
      echo ""
      if [ "$fn" = "_prov_add_firebase" ]; then
        printf "${C_RED}✗  Failed to add firebase to the project. This most likely means\n   you haven't yet accepted the Firebase terms & conditions.${C_RST}\n"
        echo ""
        printf "Press any key to open the readme..."
        read -n 1 -s -r </dev/tty || true
        printf "\r\033[K"
        chrome_open "https://github.com/almostawake/if#readme"
      fi
      return 1
    fi
  done
  return 0
}

# =====================================================================
# SECTION 3 — sign in (delegate to ~/.if/bin/auth)
# =====================================================================
# auth runs the multi-account Google OAuth flow: opens the consent
# screen, runs a Perl loopback server to catch the callback, writes
# ~/.if/creds/<email>.json with the new tokens, and prints the chosen
# email on the last line of stdout (UI to stderr). Installed by
# scripts/install-dependencies; invokable as `auth` via the zshrc alias.

echo ""
heading "let's set up a new project"
echo ""
echo "Next you'll give access to your dedicated gmail account so that"
echo "claude can administer things (only in that account) on your"
echo "behalf. When you're set, log in with that account and give access,"
echo "then come back here."
echo ""
printf "${C_GRAY}press enter to continue${C_RST}\n"
read -r _ </dev/tty 2>/dev/null || true
echo ""

EMAIL=$("$HOME/.if/bin/auth") || die "sign-in didn't complete"
[ -n "$EMAIL" ] || die "sign-in didn't complete"

CRED_FILE="$HOME/.if/creds/${EMAIL}.json"
ACCESS_TOKEN=$(json_extract access_token < "$CRED_FILE")
[ -n "$ACCESS_TOKEN" ] || die "couldn't read access_token from $CRED_FILE"

# Preflight (open billing account) gates further provisioning. Firebase
# ToS gets caught later in add_firebase via PREFLIGHT_REASON=no_firebase_tos.
if ! preflight_check; then
  print_setup_needed_terminal "$EMAIL" "$PREFLIGHT_REASON"
  exit 1
fi

# =====================================================================
# SECTION 4 — Terminal project chooser + provisioning
# =====================================================================

echo ""

# Prompts the user for a new GCP project id, validates against Google's
# rules, and creates it. Sets the global PID on success; loops on
# validation errors, ALREADY_EXISTS, etc.
prompt_create_project() {
  PID=""
  local tried_names=() candidate result joined e
  while [ -z "$PID" ]; do
    if [ ${#tried_names[@]} -gt 0 ]; then
      joined=$(printf "%s, " "${tried_names[@]}")
      joined="${joined%, }"
      printf "${C_GRAY}already tried: %s${C_RST}\n" "$joined"
    fi
    printf "project id: "
    read -r candidate </dev/tty || candidate=""
    if ! validate_gcp_project_id "$candidate"; then
      for e in "${VALIDATION_ERRORS[@]}"; do
        printf "${C_RED}✗  %s${C_RST}\n" "$e"
      done
      echo ""
      continue
    fi
    printf "${C_GRAY}⋯  creating %s${C_RST}" "$candidate"
    result=$(create_project "$candidate")
    printf "\r\033[K"
    case "$result" in
      ok)
        printf "${C_GRN}✓  %s created${C_RST}\n" "$candidate"
        PID="$candidate"
        ;;
      taken)
        printf "${C_RED}✗  %s is taken${C_RST}\n\n" "$candidate"
        tried_names+=("$candidate")
        ;;
      timeout)
        printf "${C_RED}✗  create timed out for %s${C_RST}\n\n" "$candidate"
        tried_names+=("$candidate")
        ;;
      err*)
        printf "${C_RED}✗  error creating %s (HTTP %s)${C_RST}\n\n" "$candidate" "${result#err}"
        tried_names+=("$candidate")
        ;;
      *)
        printf "${C_RED}✗  unexpected result (%s) for %s${C_RST}\n\n" "$result" "$candidate"
        tried_names+=("$candidate")
        ;;
    esac
  done
}

# Pull existing projects so we can offer reuse alongside "create a new one".
# Encouraged because (a) every Firebase-ToS-accepting user already has a
# leftover "nothing-XXXXX" shell and (b) tests of provisioning logic
# shouldn't need a fresh project each time.
list_projects || true

PID=""
if [ ${#EXISTING_PIDS[@]} -eq 0 ]; then
  prompt_create_project
else
  while [ -z "$PID" ]; do
    echo "Pick a project to provision:"
    echo ""
    n=1
    for p in "${EXISTING_PIDS[@]}"; do
      printf "%d. %s\n" "$n" "$p"
      n=$((n + 1))
    done
    printf "%d. + create a new project\n" "$n"
    echo ""
    printf "> "
    read -r choice </dev/tty || choice=""

    if [[ ! "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt "$n" ]; then
      printf "${C_RED}✗  pick a number 1-%d${C_RST}\n\n" "$n"
      continue
    fi

    if [ "$choice" -eq "$n" ]; then
      echo ""
      prompt_create_project
    else
      PID="${EXISTING_PIDS[$((choice - 1))]}"
      echo ""
      printf "${C_GRN}✓  using %s${C_RST}\n" "$PID"
    fi
  done
fi

if ! provision_all; then
  exit 1
fi

# =====================================================================
# SECTION 5 — Clone the if template, install deps, deploy
# =====================================================================
# Drops a fresh checkout into ${PROJECT_DIR}/<pid> (PROJECT_DIR comes
# from ~/.zshrc — set by scripts/install-dependencies, default
# ~/Projects), writes a root .env (PROJECT_ID + ACCOUNT_EMAIL — see
# CLAUDE.md § Deploying), installs deps, builds the client, and runs
# `node scripts/deploy.mjs`. We use scripts/deploy.mjs rather than
# `firebase deploy` because gcloud's OAuth client can't grant the
# Firebase scope; see scripts/deploy.mjs for the full reasoning.

PROJECT_PARENT="${PROJECT_DIR:-$HOME/Projects}"
PROJECT_PATH="$PROJECT_PARENT/$PID"
mkdir -p "$PROJECT_PARENT"

# Labelled step runner: prints "⋯ label" while $2... runs (output
# captured to $HTTP_LOG), replaces with "✓ label" on success or "✗ label"
# + log tail + exit on failure.
_deploy_step() {
  local label="$1"; shift
  printf "${C_GRAY}⋯  %s${C_RST}" "$label"
  if "$@" >> "$HTTP_LOG" 2>&1; then
    printf "\r\033[K${C_GRN}✓  %s${C_RST}\n" "$label"
  else
    printf "\r\033[K${C_RED}✗  %s${C_RST}\n" "$label"
    echo ""
    echo "see $HTTP_LOG for details" >&2
    exit 1
  fi
}

# Idempotent clone: if the dir already exists we leave it alone (so
# re-runs of setup-project don't nuke local edits). Fresh runs do a
# real `gh repo clone`.
_clone_template() {
  if [ -e "$PROJECT_PATH" ]; then
    echo "$PROJECT_PATH already exists — skipping clone"
    return 0
  fi
  gh repo clone almostawake/if "$PROJECT_PATH"
}

# Remove template-author-only files from the clone, replace the README
# with a per-project version, and re-init git so the user gets a clean
# single-commit history with no upstream tracking.
#
# What this strips (kept in sync with AUTHORING.md § Author-only files):
#   - AUTHORING.md
#   - scripts/install-dependencies, scripts/setup-project,
#     scripts/setup-project-bootstrap, scripts/CLAUDE-SCRIPTS.md
#   - scripts/lib/, scripts/assets/
#   - <!-- @author-only:start --> ... <!-- @author-only:end --> blocks
#     inside CLAUDE.md (the discovery pointer that hints AUTHORING.md
#     exists — irrelevant in clones)
#
# Idempotent on the file deletes (rm -f / rm -rf). git init is fine to
# re-run too — but if this function ran on an existing checkout that
# already has the user's commits, those would be lost. The orchestration
# only calls this immediately after a fresh _clone_template, so that's
# the only state we ever see.
_strip_template_only() {
  cd "$PROJECT_PATH"
  rm -f AUTHORING.md \
        scripts/auth \
        scripts/install-dependencies \
        scripts/setup-project \
        scripts/setup-project-bootstrap \
        scripts/CLAUDE-SCRIPTS.md
  rm -rf scripts/lib scripts/assets
  if [ -f CLAUDE.md ]; then
    perl -i -0pe 's/<!-- \@author-only:start -->.*?<!-- \@author-only:end -->\n?//gs' CLAUDE.md
  fi
  cat > README.md <<MDEOF
# $PID

Built from the [if](https://github.com/almostawake/if) template.

## Deploy

    node scripts/deploy.mjs

Reads \`PROJECT_ID\` + \`ACCOUNT_EMAIL\` from \`.env\` (gitignored).

## Spin up another project

    bash ~/.if/staging/scripts/setup-project
MDEOF
  rm -rf .git
  git init -q
  git add -A
  git -c user.email="$EMAIL" \
      -c user.name="if template" \
      -c commit.gpgsign=false \
      commit -q -m "initial: $PID from if template"
}

# Write the root .env that scripts/deploy.mjs reads. .env is gitignored,
# so it's per-machine state, not part of the template. ACCOUNT_EMAIL
# pins the gcloud account so multi-account machines deploy from the
# right one regardless of `gcloud config set account` drift.
_write_env() {
  local env_file="$PROJECT_PATH/.env"
  cat > "$env_file" <<ENVEOF
# Written by scripts/setup-project. .env is gitignored — local to this
# machine. scripts/deploy.mjs reads PROJECT_ID + ACCOUNT_EMAIL from here.
PROJECT_ID=$PID
ACCOUNT_EMAIL=$EMAIL
ENVEOF
}

# Seed the project owner's email into Firestore's `allowedEmails`
# collection so they can use the app on day one. The firestore.rules
# require an existing membership before allowing reads/writes — without
# this seed, the first user would be locked out and would need to add
# themselves via the Firebase Console.
#
# Schema (see client/src/lib/types/AllowedEmail.ts):
#   doc id: lowercased email
#   fields: { email, addedAt (ms epoch), addedBy }
#
# The OAuth token has cloud-platform scope, which is admin-level for
# Firestore — bypasses security rules. 200 = created, 409 = already
# exists (treated as success so re-runs are no-ops).
_seed_allowed_email() {
  local email_lc now_ms body code
  email_lc=$(printf '%s' "$EMAIL" | tr '[:upper:]' '[:lower:]')
  now_ms=$(($(date +%s) * 1000))
  body=$(printf '{"fields":{"email":{"stringValue":"%s"},"addedAt":{"integerValue":"%d"},"addedBy":{"stringValue":"%s"}}}' \
    "$email_lc" "$now_ms" "$email_lc")
  code=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $PID" \
    -H "Content-Type: application/json" \
    --data "$body" \
    "https://firestore.googleapis.com/v1/projects/$PID/databases/(default)/documents/allowedEmails?documentId=$email_lc")
  http_log "_seed_allowed_email: HTTP $code for allowedEmails/$email_lc"
  case "$code" in
    200|409) return 0 ;;
    *) return 1 ;;
  esac
}

# Fetch the Firebase Web config for the just-provisioned web app and
# write client/.env.production so the Vite build can bake it into the
# bundle. The "apiKey" returned here is a public project identifier —
# see https://firebase.google.com/docs/projects/api-keys — safe to ship
# in the client. Real auth is enforced by Firebase Auth + Firestore
# rules, not the key.
_write_client_env() {
  local list_resp app_id cfg
  list_resp=$(curl -sfL \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $PID" \
    "https://firebase.googleapis.com/v1beta1/projects/$PID/webApps") || {
      http_log "_write_client_env: webApps list failed"; return 1; }
  app_id=$(printf '%s' "$list_resp" | perl -MJSON::PP -e '
    my $j = decode_json(join("", <STDIN>));
    print $j->{apps}[0]{appId} if $j->{apps} && @{$j->{apps}};
  ')
  [ -z "$app_id" ] && { http_log "_write_client_env: no appId in webApps list"; return 1; }

  cfg=$(curl -sfL \
    -H "Authorization: Bearer $ACCESS_TOKEN" \
    -H "X-Goog-User-Project: $PID" \
    "https://firebase.googleapis.com/v1beta1/projects/$PID/webApps/$app_id/config") || {
      http_log "_write_client_env: webApps.getConfig failed for $app_id"; return 1; }

  CFG="$cfg" perl -MJSON::PP -e '
    my $c = decode_json($ENV{CFG});
    for my $k (qw(apiKey authDomain projectId storageBucket messagingSenderId appId)) {
      die "missing $k in webApps.getConfig response\n" unless defined $c->{$k};
    }
    print "VITE_FIREBASE_API_KEY=$c->{apiKey}\n";
    print "VITE_FIREBASE_AUTH_DOMAIN=$c->{authDomain}\n";
    print "VITE_FIREBASE_PROJECT_ID=$c->{projectId}\n";
    print "VITE_FIREBASE_STORAGE_BUCKET=$c->{storageBucket}\n";
    print "VITE_FIREBASE_MESSAGING_SENDER_ID=$c->{messagingSenderId}\n";
    print "VITE_FIREBASE_APP_ID=$c->{appId}\n";
  ' > "$PROJECT_PATH/client/.env.production"
}

_install_deps() { ( cd "$PROJECT_PATH" && npm run install:all ); }

# scripts/deploy.mjs reads PROJECT_ID + ACCOUNT_EMAIL from .env, runs
# the build itself, then pushes hosting + firestore rules. We pass
# GOOGLE_ACCESS_TOKEN explicitly here to skip the cred-file/gcloud
# round-trip (we already have a fresh token from earlier in the script).
_deploy_to_fb() {
  ( cd "$PROJECT_PATH" && \
    GOOGLE_ACCESS_TOKEN="$ACCESS_TOKEN" node scripts/deploy.mjs )
}

echo ""
heading "now: clone, install, deploy"
echo ""
_deploy_step "cloning if template into $PROJECT_PATH" _clone_template
_deploy_step "stripping template-only files + fresh git init" _strip_template_only
_deploy_step "writing .env (PROJECT_ID, ACCOUNT_EMAIL)" _write_env
_deploy_step "writing client/.env.production (firebase web config)" _write_client_env
_deploy_step "seeding $EMAIL as initial allowed user" _seed_allowed_email
_deploy_step "installing dependencies (this can take a minute)" _install_deps
_deploy_step "building + deploying to firebase" _deploy_to_fb

echo ""
heading "project ready"
echo ""
printf "Live at: ${C_BLU}https://%s.web.app${C_RST}\n" "$PID"
printf "Code:    %s\n" "$PROJECT_PATH"
echo ""
